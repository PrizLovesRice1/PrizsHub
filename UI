-- ─── Notification System ────────────────────────────────────────────────────

local notifGui = nil
local notifList = nil

local function ensureNotifGui()
    if notifGui and notifGui.Parent then return end
    notifGui = Instance.new("ScreenGui")
    notifGui.Name = "OrionNotifs"
    notifGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    notifGui.ResetOnSpawn = false
    notifGui.Parent = game.CoreGui

    notifList = Instance.new("Frame")
    notifList.Name = "NotifList"
    notifList.BackgroundTransparency = 1
    notifList.Position = UDim2.new(1, -20, 1, -20)
    notifList.AnchorPoint = Vector2.new(1, 1)
    notifList.Size = UDim2.new(0, 300, 1, 0)
    notifList.Parent = notifGui

    local list = Instance.new("UIListLayout")
    list.Parent = notifList
    list.SortOrder = Enum.SortOrder.LayoutOrder
    list.VerticalAlignment = Enum.VerticalAlignment.Bottom
    list.Padding = UDim.new(0, 6)
end

function OrionLib:Notify(opts)
    opts = opts or {}
    local title    = opts.Title    or "Notification"
    local content  = opts.Content  or ""
    local duration = opts.Duration or 5

    ensureNotifGui()

    local card = Instance.new("Frame")
    card.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    card.BorderSizePixel  = 0
    card.Size             = UDim2.new(1, 0, 0, 60)
    card.BackgroundTransparency = 1
    card.Parent = notifList

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 5)
    corner.Parent = card

    local accent = Instance.new("Frame")
    accent.BackgroundColor3 = Color3.fromRGB(181, 1, 31)
    accent.BorderSizePixel  = 0
    accent.Size             = UDim2.new(0, 4, 1, 0)
    accent.Parent = card
    local ac = Instance.new("UICorner"); ac.CornerRadius = UDim.new(0,3); ac.Parent = accent

    local titleLbl = Instance.new("TextLabel")
    titleLbl.BackgroundTransparency = 1
    titleLbl.Position = UDim2.new(0, 12, 0, 6)
    titleLbl.Size     = UDim2.new(1, -16, 0, 22)
    titleLbl.Font     = Enum.Font.GothamSemibold
    titleLbl.Text     = title
    titleLbl.TextColor3 = Color3.fromRGB(255,255,255)
    titleLbl.TextSize = 14
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.Parent = card

    local contentLbl = Instance.new("TextLabel")
    contentLbl.BackgroundTransparency = 1
    contentLbl.Position = UDim2.new(0, 12, 0, 30)
    contentLbl.Size     = UDim2.new(1, -16, 0, 22)
    contentLbl.Font     = Enum.Font.Gotham
    contentLbl.Text     = content
    contentLbl.TextColor3 = Color3.fromRGB(180,180,180)
    contentLbl.TextSize = 13
    contentLbl.TextXAlignment = Enum.TextXAlignment.Left
    contentLbl.TextTruncate = Enum.TextTruncate.AtEnd
    contentLbl.Parent = card

    -- slide in
    game.TweenService:Create(card, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
        BackgroundTransparency = 0
    }):Play()

    task.delay(duration, function()
        game.TweenService:Create(card, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
            BackgroundTransparency = 1
        }):Play()
        task.wait(0.3)
        card:Destroy()
    end)
end

