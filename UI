					switchBg.BackgroundColor3=SelectedTheme.ToggleBackground
					if not ToggleSettings.CurrentValue then
						outerStroke.Color=SelectedTheme.ToggleDisabledOuterStroke
						knob.BackgroundColor3=SelectedTheme.ToggleDisabled
						knobStroke.Color=SelectedTheme.ToggleDisabledStroke
					else
						outerStroke.Color=SelectedTheme.ToggleEnabledOuterStroke
						knob.BackgroundColor3=SelectedTheme.ToggleEnabled
						knobStroke.Color=SelectedTheme.ToggleEnabledStroke
					end
				end
			end)

			local function applyToggle(val)
				ToggleSettings.CurrentValue=val
				if val then
					tw(knob,0.3,{Position=UDim2.new(0,25,0.5,-7),BackgroundColor3=SelectedTheme.ToggleEnabled})
					tw(knobStroke,0.3,{Color=SelectedTheme.ToggleEnabledStroke})
					tw(outerStroke,0.3,{Color=SelectedTheme.ToggleEnabledOuterStroke})
				else
					tw(knob,0.3,{Position=UDim2.new(0,3,0.5,-7),BackgroundColor3=SelectedTheme.ToggleDisabled})
					tw(knobStroke,0.3,{Color=SelectedTheme.ToggleDisabledStroke})
					tw(outerStroke,0.3,{Color=SelectedTheme.ToggleDisabledOuterStroke})
				end
			end
			applyToggle(ToggleSettings.CurrentValue or false)

			click.MouseButton1Click:Connect(function()
				applyToggle(not ToggleSettings.CurrentValue)
				local ok,err=pcall(ToggleSettings.Callback or function()end, ToggleSettings.CurrentValue)
				if not ok then warn("Toggle callback error: "..tostring(err)) end
				if not ToggleSettings.Ext then SaveConfiguration() end
			end)

			function ToggleSettings:Set(v)
				applyToggle(v)
				pcall(ToggleSettings.Callback or function()end, v)
				if not ToggleSettings.Ext then SaveConfiguration() end
			end

			if Settings.ConfigurationSaving and Settings.ConfigurationSaving.Enabled and ToggleSettings.Flag and not ToggleSettings.Ext then
				RayfieldLibrary.Flags[ToggleSettings.Flag]=ToggleSettings
			end
			return ToggleSettings
		end

		-- ── CreateSlider ──────────────────────────────────────────────────────
		function Tab:CreateSlider(SliderSettings)
			SliderSettings=SliderSettings or{}
			SliderSettings.Type="Slider"
			local min=SliderSettings.Range[1]; local max=SliderSettings.Range[2]
			local inc=SliderSettings.Increment or 1
			local cur=math.clamp(SliderSettings.CurrentValue or min, min, max)
			SliderSettings.CurrentValue=cur

			local f=baseFrame(56)
			titleLabel(f, SliderSettings.Name or "Slider")

			local valLbl=New("TextLabel",{Text=tostring(cur)..(SliderSettings.Suffix and " "..SliderSettings.Suffix or ""),Font=Enum.Font.Gotham,TextSize=13,TextColor3=SelectedTheme.TextColor,BackgroundTransparency=1,Size=UDim2.new(0,90,0,18),Position=UDim2.new(1,-102,0,6),TextXAlignment=Enum.TextXAlignment.Right,ZIndex=2,Parent=f})
			addThemeCb(function() if valLbl and valLbl.Parent then valLbl.TextColor3=SelectedTheme.TextColor end end)

			local trackBg=New("Frame",{BackgroundColor3=SelectedTheme.SliderBackground,Size=UDim2.new(1,-24,0,8),Position=UDim2.new(0,12,0,38),BorderSizePixel=0,ZIndex=2,Parent=f})
			corner(4,trackBg); stroke(SelectedTheme.SliderStroke,1,trackBg)

			local frac=(cur-min)/(max-min)
			local fillFrm=New("Frame",{BackgroundColor3=SelectedTheme.SliderProgress,Size=UDim2.new(frac,0,1,0),BorderSizePixel=0,ZIndex=3,Parent=trackBg})
			corner(4,fillFrm)

			local interact=New("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),ZIndex=4,Parent=trackBg})

			addThemeCb(function()
				if trackBg and trackBg.Parent then
					trackBg.BackgroundColor3=SelectedTheme.SliderBackground
					trackBg.UIStroke.Color=SelectedTheme.SliderStroke
					fillFrm.BackgroundColor3=SelectedTheme.SliderProgress
				end
			end)

			local dragging=false
			interact.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true tw(trackBg.UIStroke,0.2,{Transparency=1}) end end)
			interact.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false tw(trackBg.UIStroke,0.2,{Transparency=0}) end end)
			UIS.InputChanged:Connect(function(i)
				if not dragging then return end
				if i.UserInputType~=Enum.UserInputType.MouseMovement then return end
				local raw=(i.Position.X-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X
				local frac2=math.clamp(raw,0,1)
				local rawVal=min+(max-min)*frac2
				local snapped=math.floor(rawVal/inc+0.5)*inc
				snapped=math.clamp(snapped,min,max)
				tw(fillFrm,0.1,{Size=UDim2.new(frac2,0,1,0)})
				valLbl.Text=tostring(snapped)..(SliderSettings.Suffix and " "..SliderSettings.Suffix or "")
				if SliderSettings.CurrentValue~=snapped then
					SliderSettings.CurrentValue=snapped
					pcall(SliderSettings.Callback or function()end, snapped)
					if not SliderSettings.Ext then SaveConfiguration() end
				end
			end)

			function SliderSettings:Set(v)
				v=math.clamp(v,min,max)
				self.CurrentValue=v
				local f2=(v-min)/(max-min)
				tw(fillFrm,0.2,{Size=UDim2.new(f2,0,1,0)})
				valLbl.Text=tostring(v)..(self.Suffix and " "..self.Suffix or "")
				pcall(self.Callback or function()end, v)
				if not self.Ext then SaveConfiguration() end
			end

			if Settings.ConfigurationSaving and Settings.ConfigurationSaving.Enabled and SliderSettings.Flag and not SliderSettings.Ext then
				RayfieldLibrary.Flags[SliderSettings.Flag]=SliderSettings
			end
			return SliderSettings
		end

