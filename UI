				addThemeCb(function() if wrap and wrap.Parent then wrap.BackgroundColor3=SelectedTheme.InputBackground wrap.UIStroke.Color=SelectedTheme.InputStroke box.TextColor3=SelectedTheme.TextColor end end)
				return box
			end
			local rBox=makeRGBBox(0,"R"); local gBox=makeRGBBox(56,"G"); local bBox=makeRGBBox(112,"B")

			-- Hex input
			local hexWrap=New("Frame",{BackgroundColor3=SelectedTheme.InputBackground,Size=UDim2.new(0,86,0,22),Position=UDim2.new(0,168,0,108),BorderSizePixel=0,Parent=panel})
			corner(4,hexWrap); stroke(SelectedTheme.InputStroke,1,hexWrap)
			local hexBox=New("TextBox",{Text="#FFFFFF",Font=Enum.Font.Gotham,TextSize=12,TextColor3=SelectedTheme.TextColor,BackgroundTransparency=1,Size=UDim2.new(1,-8,1,0),Position=UDim2.new(0,4,0,0),ClearTextOnFocus=false,Parent=hexWrap})
			addThemeCb(function() if hexWrap and hexWrap.Parent then hexWrap.BackgroundColor3=SelectedTheme.InputBackground hexWrap.UIStroke.Color=SelectedTheme.InputStroke hexBox.TextColor3=SelectedTheme.TextColor end end)

			local function updateDisplay()
				local c=Color3.fromHSV(h_,s_,v_)
				ColorPickerSettings.Color=c; preview.BackgroundColor3=c
				svBg.BackgroundColor3=Color3.fromHSV(h_,1,1)
				local r,g,b=math.floor(c.R*255+0.5),math.floor(c.G*255+0.5),math.floor(c.B*255+0.5)
				rBox.Text=tostring(r); gBox.Text=tostring(g); bBox.Text=tostring(b)
				hexBox.Text=string.format("#%02X%02X%02X",r,g,b)
				pcall(ColorPickerSettings.Callback or function()end, c)
				if not ColorPickerSettings.Ext then SaveConfiguration() end
			end
			updateDisplay()

			-- SV drag
			local svDrag=false
			svBg.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then svDrag=true end end)
			svBg.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then svDrag=false end end)
			UIS.InputChanged:Connect(function(i)
				if svDrag and i.UserInputType==Enum.UserInputType.MouseMovement then
					s_=math.clamp((i.Position.X-svBg.AbsolutePosition.X)/svBg.AbsoluteSize.X,0,1)
					v_=1-math.clamp((i.Position.Y-svBg.AbsolutePosition.Y)/svBg.AbsoluteSize.Y,0,1)
					svCursor.Position=UDim2.new(s_,0,1-v_,0); updateDisplay()
				end
			end)

			-- Hue drag
			local hueDrag=false
			hueBar.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then hueDrag=true end end)
			hueBar.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then hueDrag=false end end)
			UIS.InputChanged:Connect(function(i)
				if hueDrag and i.UserInputType==Enum.UserInputType.MouseMovement then
					h_=1-math.clamp((i.Position.Y-hueBar.AbsolutePosition.Y)/hueBar.AbsoluteSize.Y,0,1)
					hueCursor.Position=UDim2.new(0.5,0,1-h_,0); updateDisplay()
				end
			end)

			-- RGB inputs
			local function applyRGB()
				local r,g,b=tonumber(rBox.Text),tonumber(gBox.Text),tonumber(bBox.Text)
				if r and g and b then
					h_,s_,v_=Color3.fromRGB(math.clamp(r,0,255),math.clamp(g,0,255),math.clamp(b,0,255)):ToHSV()
					svCursor.Position=UDim2.new(s_,0,1-v_,0); hueCursor.Position=UDim2.new(0.5,0,1-h_,0); updateDisplay()
				end
			end
			rBox.FocusLost:Connect(applyRGB); gBox.FocusLost:Connect(applyRGB); bBox.FocusLost:Connect(applyRGB)

			hexBox.FocusLost:Connect(function()
				local hex=hexBox.Text:gsub("#","")
				if #hex==6 then
					local r,g,b=tonumber(hex:sub(1,2),16),tonumber(hex:sub(3,4),16),tonumber(hex:sub(5,6),16)
					if r and g and b then h_,s_,v_=Color3.fromRGB(r,g,b):ToHSV() svCursor.Position=UDim2.new(s_,0,1-v_,0) hueCursor.Position=UDim2.new(0.5,0,1-h_,0) updateDisplay() end
				end
			end)

			-- open/close toggle
			local cpOpen=false
			local headerBtn=New("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),ZIndex=3,Parent=f})
			hoverSetup(f,headerBtn)
			headerBtn.MouseButton1Click:Connect(function()
				cpOpen=not cpOpen
				if cpOpen then
					wrapper.ClipsDescendants=false
					tw(wrapper,0.3,{Size=UDim2.new(1,0,0,38+8+155)})
				else
					tw(wrapper,0.3,{Size=UDim2.new(1,0,0,38)})
					task.delay(0.3,function() wrapper.ClipsDescendants=true end)
				end
				updateCanvas()
			end)

			function ColorPickerSettings:Set(c)
				self.Color=c; h_,s_,v_=c:ToHSV()
				svCursor.Position=UDim2.new(s_,0,1-v_,0); hueCursor.Position=UDim2.new(0.5,0,1-h_,0); updateDisplay()
			end

			if Settings.ConfigurationSaving and Settings.ConfigurationSaving.Enabled and ColorPickerSettings.Flag and not ColorPickerSettings.Ext then
				RayfieldLibrary.Flags[ColorPickerSettings.Flag]=ColorPickerSettings
			end
			return ColorPickerSettings
		end

		return Tab
	end

	-- ── Window methods ────────────────────────────────────────────────────────
	function Window.ModifyTheme(newTheme)
		local ok=ChangeTheme(newTheme)
		if ok then
			RayfieldLibrary:Notify({Title="Theme Changed",Content="Theme set to "..(type(newTheme)=="string" and newTheme or "Custom")..".",Duration=3})
		else
			RayfieldLibrary:Notify({Title="Theme Error",Content="Theme not found.",Duration=3})
		end
	end

	-- Discord auto-join
	if Settings.Discord and Settings.Discord.Enabled and not RS:IsStudio() then
		ensureFolder("Rayfield/Discord Invites")
		local inv=Settings.Discord.Invite or ""
		local dpath="Rayfield/Discord Invites/"..inv..".rfld"
		if inv~="" and not (isfile and callSafely(isfile,dpath)) then
			pcall(function()
				local requestFunc=(syn and syn.request) or http_request or request
				if requestFunc then
					requestFunc({Url="http://127.0.0.1:6463/rpc?v=1",Method="POST",Headers={["Content-Type"]="application/json",Origin="https://discord.com"},Body=HTTP:JSONEncode({cmd="INVITE_BROWSER",nonce=HTTP:GenerateGUID(false),args={code=inv}})})
				end
			end)
			if Settings.Discord.RememberJoins then callSafely(writefile,dpath,"joined") end
		end
	end

	-- defer config load
	task.delay(3.5,function()
		RayfieldLibrary:LoadConfiguration()
	end)

	return Window
end

-- ── Visibility helpers ────────────────────────────────────────────────────────
function RayfieldLibrary:SetVisibility(v)
	Hidden = not v
end
function RayfieldLibrary:IsVisible()
	return not Hidden
end

-- ── Destroy ───────────────────────────────────────────────────────────────────
function RayfieldLibrary:Destroy()
	rayfieldDestroyed=true
	for _,c in ipairs(keybindConnections) do pcall(function() c:Disconnect() end) end
	Orion:Destroy()
end

return RayfieldLibrary
