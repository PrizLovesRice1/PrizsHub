            toggleInnerFrame1.Parent           = toggleInerFrame
            toggleInnerFrame1.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            toggleInnerFrame1.Position         = UDim2.new(0, 1, 0, 1)
            toggleInnerFrame1.Size             = UDim2.new(0, 25, 0, 25)
            corner3.CornerRadius               = UDim.new(0, 3)
            corner3.Parent                     = toggleInnerFrame1

            toggleBtn.Parent           = toggleInnerFrame1
            toggleBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
            toggleBtn.Size             = UDim2.new(0, 23, 0, 23)
            toggleBtn.Position         = UDim2.new(0.09, 0, 0.04, 0)
            toggleBtn.Font             = Enum.Font.GothamSemibold
            toggleBtn.Text             = ""
            toggleBtn.AutoButtonColor  = false
            corner4.CornerRadius       = UDim.new(0, 3)
            corner4.Parent             = toggleBtn

            ULL1.Parent = toggleInnerFrame1; ULL1.HorizontalAlignment = Enum.HorizontalAlignment.Center; ULL1.SortOrder = Enum.SortOrder.LayoutOrder; ULL1.VerticalAlignment = Enum.VerticalAlignment.Center
            ULL2.Parent = toggleInerFrame;   ULL2.HorizontalAlignment = Enum.HorizontalAlignment.Center; ULL2.SortOrder = Enum.SortOrder.LayoutOrder; ULL2.VerticalAlignment = Enum.VerticalAlignment.Center

            local toggled = currentVal
            local function applyState()
                if toggled then
                    TweenService:Create(toggleBtn, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),{ BackgroundColor3 = Color3.fromRGB(181, 1, 31) }):Play()
                else
                    TweenService:Create(toggleBtn, TweenInfo.new(0.18, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),{ BackgroundColor3 = Color3.fromRGB(25, 25, 25) }):Play()
                end
            end
            applyState()
            if flag then OrionLib.Flags[flag] = toggled end

            toggleBtn.MouseButton1Click:Connect(function()
                toggled = not toggled
                applyState()
                if flag then OrionLib.Flags[flag] = toggled end
                callback(toggled)
            end)

            local obj = { CurrentValue = toggled }
            function obj:Set(value)
                toggled = value
                obj.CurrentValue = toggled
                applyState()
                if flag then OrionLib.Flags[flag] = toggled end
                callback(toggled)
            end
            return obj
        end

