-- ─── ChangeTheme ──────────────────────────────────────────────────────────────
local themeCallbacks = {}
local function addThemeCb(fn) table.insert(themeCallbacks,fn) end

local function ChangeTheme(t)
	if type(t)=="string" and RayfieldLibrary.Theme[t] then
		SelectedTheme = RayfieldLibrary.Theme[t]
	elseif type(t)=="table" then
		SelectedTheme = t
	else return false end
	for _,fn in ipairs(themeCallbacks) do pcall(fn) end
	return true
end

-- ─── Dragging ─────────────────────────────────────────────────────────────────
local function MakeDraggable(handle, target)
	local dragging, rel = false
	handle.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
			dragging=true
			rel = target.AbsolutePosition + target.AbsoluteSize*target.AnchorPoint - UIS:GetMouseLocation()
			i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then dragging=false end end)
		end
	end)
	UIS.InputChanged:Connect(function(i)
		if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
			local p = UIS:GetMouseLocation()+rel
			tw(target,0.05,{Position=UDim2.fromOffset(p.X,p.Y)})
		end
	end)
end

-- ─── Key System ───────────────────────────────────────────────────────────────
local function RunKeySystem(KeySettings)
	local keys = KeySettings.Key or {}
	if type(keys)=="string" then keys={keys} end
	local maxAttempts = KeySettings.MaxAttempts or 5
	local attempts = 0
	local passed = false

	-- grab from site
	if KeySettings.GrabKeyFromSite then
		for i,k in ipairs(keys) do
			local ok,res = pcall(function() return game:HttpGet(k):gsub("[\n\r ]","") end)
			if ok then keys[i]=res end
		end
	end

	-- check saved
	local ksFolder = "Rayfield/Key System"
	ensureFolder(ksFolder)
	if KeySettings.FileName and isfile and callSafely(isfile, ksFolder.."/"..KeySettings.FileName..".rfld") then
		local saved = callSafely(readfile, ksFolder.."/"..KeySettings.FileName..".rfld")
		for _,k in ipairs(keys) do if saved==k then passed=true break end end
	end
	if passed then return true end

	-- UI
	local bg = New("Frame",{
		BackgroundColor3=SelectedTheme.Background, Size=UDim2.new(0,500,0,190),
		Position=UDim2.new(0.5,-250,0.5,-95), Parent=Orion, BackgroundTransparency=1,
	})
	corner(12,bg); stroke(SelectedTheme.ElementStroke,1.5,bg)

	New("TextLabel",{Text=KeySettings.Title or "Key System",Font=Enum.Font.GothamBold,TextSize=18,TextColor3=SelectedTheme.TextColor,BackgroundTransparency=1,Size=UDim2.new(1,0,0,30),Position=UDim2.new(0,0,0,16),TextXAlignment=Enum.TextXAlignment.Center,Parent=bg})
	New("TextLabel",{Text=KeySettings.Subtitle or "Enter key to continue",Font=Enum.Font.Gotham,TextSize=13,TextColor3=SelectedTheme.TextColor,BackgroundTransparency=1,Size=UDim2.new(1,-40,0,18),Position=UDim2.new(0,20,0,52),TextXAlignment=Enum.TextXAlignment.Center,Parent=bg})

	local note = KeySettings.Note or ""
	if note~="" then New("TextLabel",{Text=note,Font=Enum.Font.Gotham,TextSize=12,TextColor3=SelectedTheme.TextColor,BackgroundTransparency=1,Size=UDim2.new(1,-40,0,14),Position=UDim2.new(0,20,0,74),TextXAlignment=Enum.TextXAlignment.Center,TextWrapped=true,Parent=bg}) end

	local inputFrame = New("Frame",{BackgroundColor3=SelectedTheme.InputBackground,Size=UDim2.new(1,-40,0,36),Position=UDim2.new(0,20,0,100),Parent=bg})
	corner(8,inputFrame); stroke(SelectedTheme.InputStroke,1,inputFrame)
	local inputBox = New("TextBox",{Text="",PlaceholderText="Enter key...",Font=Enum.Font.GothamSemibold,TextSize=14,TextColor3=SelectedTheme.TextColor,PlaceholderColor3=SelectedTheme.PlaceholderColor,BackgroundTransparency=1,Size=UDim2.new(1,-16,1,0),Position=UDim2.new(0,8,0,0),ClearTextOnFocus=false,Parent=inputFrame})

	local statusLbl = New("TextLabel",{Text="",Font=Enum.Font.Gotham,TextSize=12,TextColor3=Color3.fromRGB(255,80,80),BackgroundTransparency=1,Size=UDim2.new(1,-40,0,14),Position=UDim2.new(0,20,0,144),TextXAlignment=Enum.TextXAlignment.Center,Parent=bg})

	local submitBtn = New("TextButton",{Text="Submit",Font=Enum.Font.GothamBold,TextSize=14,TextColor3=Color3.fromRGB(255,255,255),BackgroundColor3=SelectedTheme.SliderProgress,Size=UDim2.new(0,110,0,30),Position=UDim2.new(0.5,-55,0,156),Parent=bg})
	corner(8,submitBtn)

	tw(bg,0.5,{BackgroundTransparency=0})

	local done = false
	submitBtn.MouseButton1Click:Connect(function()
		local entered = inputBox.Text
		local found = false
		local foundKey
		for _,k in ipairs(keys) do if entered==k then found=true foundKey=k break end end
		if found then
			if KeySettings.SaveKey and KeySettings.FileName then
				ensureFolder(ksFolder)
				callSafely(writefile, ksFolder.."/"..KeySettings.FileName..".rfld", foundKey)
			end
			tw(bg,0.4,{BackgroundTransparency=1})
			task.wait(0.45); bg:Destroy(); done=true; passed=true
		else
			attempts+=1
			if attempts>=maxAttempts then
				statusLbl.Text="Too many attempts."
				task.wait(1); bg:Destroy(); done=true
			else
				statusLbl.Text="Invalid key. "..attempts.."/"..maxAttempts.." attempts."
				tw(bg,0.08,{Position=UDim2.new(0.5,-255,0.5,-95)})
				task.wait(0.1); tw(bg,0.08,{Position=UDim2.new(0.5,-245,0.5,-95)})
				task.wait(0.1); tw(bg,0.08,{Position=UDim2.new(0.5,-250,0.5,-95)})
			end
		end
	end)

	inputBox.FocusLost:Connect(function(enter)
		if enter then submitBtn.MouseButton1Click:Fire() end
	end)

	while not done do task.wait(0.1) end
	return passed
end

-- ─── CreateWindow ─────────────────────────────────────────────────────────────
function RayfieldLibrary:CreateWindow(Settings)
	Settings = Settings or {}
	Settings.Name = Settings.Name or "OrionLib"
	Settings.Theme = Settings.Theme or "Default"
	Settings.LoadingTitle = Settings.LoadingTitle or Settings.Name
	Settings.LoadingSubtitle = Settings.LoadingSubtitle or "Interface Suite"

	-- apply theme
	ChangeTheme(Settings.Theme)

	-- config setup
	if Settings.ConfigurationSaving then
		CEnabled = Settings.ConfigurationSaving.Enabled or false
		CFileName = Settings.ConfigurationSaving.FileName or tostring(game.PlaceId)
		CFolder = (Settings.ConfigurationSaving.FolderName or "Rayfield").."/Configurations"
		if CEnabled then
			ensureFolder("Rayfield"); ensureFolder(CFolder)
		end
	end

	-- ── Main Window ──────────────────────────────────────────────────────────
	local Main = New("Frame",{
		BackgroundColor3=SelectedTheme.Background,
		Size=UDim2.new(0,500,0,475),
		Position=UDim2.new(0.5,-250,0.5,-237),
		AnchorPoint=Vector2.new(0,0),
		ClipsDescendants=false,
		Parent=Orion,
	})
	corner(10,Main); stroke(SelectedTheme.ElementStroke,1,Main)
	addThemeCb(function() Main.BackgroundColor3=SelectedTheme.Background Main.UIStroke.Color=SelectedTheme.ElementStroke end)

	-- ── Topbar ───────────────────────────────────────────────────────────────
	local Topbar = New("Frame",{
		Name="Topbar", BackgroundColor3=SelectedTheme.Topbar,
		Size=UDim2.new(1,0,0,45), BorderSizePixel=0, ZIndex=2, Parent=Main,
	})
	corner(10,Topbar)
	-- cover bottom-corners of topbar
	New("Frame",{BackgroundColor3=SelectedTheme.Topbar,Size=UDim2.new(1,0,0,12),Position=UDim2.new(0,0,1,-12),BorderSizePixel=0,ZIndex=2,Parent=Topbar})
	local topDivider = New("Frame",{BackgroundColor3=SelectedTheme.ElementStroke,Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BorderSizePixel=0,ZIndex=2,Parent=Topbar})
	addThemeCb(function() Topbar.BackgroundColor3=SelectedTheme.Topbar topDivider.BackgroundColor3=SelectedTheme.ElementStroke end)

	local TitleLbl = New("TextLabel",{
		Text=Settings.Name, Font=Enum.Font.GothamBlack, TextSize=17,
		TextColor3=SelectedTheme.TextColor, BackgroundTransparency=1,
		Size=UDim2.new(1,-200,1,0), Position=UDim2.new(0,15,0,0),
		TextXAlignment=Enum.TextXAlignment.Left, ZIndex=3, Parent=Topbar,
	})
	addThemeCb(function() TitleLbl.TextColor3=SelectedTheme.TextColor end)

	-- icon
	if Settings.Icon and Settings.Icon~=0 then
		local ico = New("ImageLabel",{Image=type(Settings.Icon)=="number" and "rbxassetid://"..Settings.Icon or tostring(Settings.Icon),BackgroundTransparency=1,Size=UDim2.new(0,20,0,20),Position=UDim2.new(0,14,0.5,-10),ZIndex=3,Parent=Topbar})
		TitleLbl.Position = UDim2.new(0,42,0,0)
	end

	-- topbar buttons
	local function MakeTopBtn(xOff, imgId)
		local btn = New("ImageButton",{
			Image="rbxassetid://"..imgId, BackgroundTransparency=1,
			Size=UDim2.new(0,18,0,18),
			Position=UDim2.new(1,-xOff,0.5,-9),
			ImageColor3=SelectedTheme.TextColor, ImageTransparency=0.2,
			ZIndex=3, Parent=Topbar,
		})
		btn.MouseEnter:Connect(function() tw(btn,0.3,{ImageTransparency=0}) end)
		btn.MouseLeave:Connect(function() tw(btn,0.3,{ImageTransparency=0.2}) end)
		addThemeCb(function() btn.ImageColor3=SelectedTheme.TextColor end)
		return btn
	end

	local HideBtn     = MakeTopBtn(20,  10137832201)   -- hide icon
	local ChangeSzBtn = MakeTopBtn(44,  10137941941)   -- minimise icon
	local SearchBtn   = MakeTopBtn(68,  7072719338)    -- search/magnifier

	-- drag via topbar (left portion only so buttons still clickable)
	local DragHandle = New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,-120,1,0),ZIndex=2,Parent=Topbar})
	MakeDraggable(DragHandle, Main)

	-- ── Search overlay ───────────────────────────────────────────────────────
	local SearchFrame = New("Frame",{
		Name="Search", BackgroundColor3=SelectedTheme.TextColor,
		Size=UDim2.new(1,-35,0,35), Position=UDim2.new(0.5,0,0,57),
		AnchorPoint=Vector2.new(0.5,0), ZIndex=5, Visible=false, Parent=Main,
	})
	corner(8,SearchFrame); stroke(SelectedTheme.SecondaryElementStroke,1,SearchFrame)
	local SearchInput = New("TextBox",{
		Text="", PlaceholderText="Search elements...",
		Font=Enum.Font.Gotham, TextSize=14,
		TextColor3=SelectedTheme.Background, PlaceholderColor3=SelectedTheme.Background,
		BackgroundTransparency=1, Size=UDim2.new(1,-36,1,0),
		Position=UDim2.new(0,32,0,0), ZIndex=5, ClearTextOnFocus=false, Parent=SearchFrame,
	})
	addThemeCb(function() SearchFrame.BackgroundColor3=SelectedTheme.TextColor SearchFrame.UIStroke.Color=SelectedTheme.SecondaryElementStroke SearchInput.TextColor3=SelectedTheme.Background end)

	-- ── Tab sidebar ──────────────────────────────────────────────────────────
	local TabList = New("ScrollingFrame",{
		Name="TabList", BackgroundTransparency=1,
		Size=UDim2.new(1,0,0,38), Position=UDim2.new(0,0,0,50),
		BorderSizePixel=0, ScrollBarThickness=0, CanvasSize=UDim2.new(0,0,0,0),
		ScrollingDirection=Enum.ScrollingDirection.X, ZIndex=2, Parent=Main,
	})
	local tabLL = listLayout(TabList,6,Enum.FillDirection.Horizontal)
	padding(0,0,10,10,TabList)
	tabLL.HorizontalAlignment = Enum.HorizontalAlignment.Left
	tabLL.VerticalAlignment   = Enum.VerticalAlignment.Center

	TabList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		TabList.CanvasSize = UDim2.new(0,tabLL.AbsoluteContentSize.X+20,0,0)
	end)

	-- ── Elements area ─────────────────────────────────────────────────────────
	local ElementsContainer = New("Frame",{
		BackgroundTransparency=1,
		Size=UDim2.new(1,0,1,-90),
		Position=UDim2.new(0,0,0,88),
		ClipsDescendants=true, Parent=Main,
	})

	-- ── Loading screen ───────────────────────────────────────────────────────
	local LoadFrame = New("Frame",{
		BackgroundColor3=SelectedTheme.Background, Size=UDim2.new(1,0,1,0),
		ZIndex=10, Parent=Main,
	})
	corner(10,LoadFrame)
	local loadLL = listLayout(LoadFrame,6)
	loadLL.HorizontalAlignment=Enum.HorizontalAlignment.Center
	loadLL.VerticalAlignment=Enum.VerticalAlignment.Center
	local loadTitle = New("TextLabel",{Text=Settings.LoadingTitle,Font=Enum.Font.GothamBlack,TextSize=22,TextColor3=SelectedTheme.TextColor,BackgroundTransparency=1,Size=UDim2.new(1,0,0,28),TextXAlignment=Enum.TextXAlignment.Center,ZIndex=11,Parent=LoadFrame})
	local loadSub   = New("TextLabel",{Text=Settings.LoadingSubtitle,Font=Enum.Font.Gotham,TextSize=15,TextColor3=SelectedTheme.TextColor,BackgroundTransparency=1,Size=UDim2.new(1,0,0,20),TextXAlignment=Enum.TextXAlignment.Center,ZIndex=11,Parent=LoadFrame})
	addThemeCb(function() LoadFrame.BackgroundColor3=SelectedTheme.Background loadTitle.TextColor3=SelectedTheme.TextColor loadSub.TextColor3=SelectedTheme.TextColor end)

	-- animate loading out
	task.spawn(function()
		task.wait(1.5)
		tw(loadTitle,0.3,{TextTransparency=1})
		tw(loadSub,0.3,{TextTransparency=1})
		task.wait(0.3)
		tw(LoadFrame,0.4,{BackgroundTransparency=1})
		task.wait(0.45)
		LoadFrame:Destroy()
	end)

	-- ── Key system ───────────────────────────────────────────────────────────
	if Settings.KeySystem and Settings.KeySettings then
		local passed = RunKeySystem(Settings.KeySettings)
		if not passed then
			RayfieldLibrary:Notify({Title="Access Denied",Content="Key system failed.",Duration=5})
			Main:Destroy()
			return {}
		end
	end

	-- ── Hide / Unhide / Minimise / Maximise ──────────────────────────────────
	local function setElements(show)
		for _,page in ipairs(ElementsContainer:GetChildren()) do
			if page:IsA("ScrollingFrame") then
				for _,el in ipairs(page:GetChildren()) do
					if el:IsA("Frame") then el.Visible=show end
				end
			end
		end
	end

	local function Unhide()
		Debounce=true; Hidden=false
		Main.Visible=true
		tw(Main,0.5,{Size=UDim2.new(0,500,0,475)})
		tw(Topbar,0.5,{BackgroundTransparency=0})
		task.wait(0.5); Debounce=false
	end

	local function HideUI(notify)
		if Debounce then return end
		Debounce=true; Hidden=true
		tw(Main,0.4,{Size=UDim2.new(0,500,0,0)})
		task.wait(0.4)
		Main.Visible=false; Debounce=false
		if notify then
			local key = Settings.ToggleUIKeybind
			local keyName = type(key)=="string" and key or (typeof(key)=="EnumItem" and key.Name or "K")
			RayfieldLibrary:Notify({Title="Interface Hidden",Content="Press "..keyName.." to reopen.",Duration=5})
		end
	end

	local function Maximise()
		Debounce=true; Minimised=false
		tw(Main,0.5,{Size=UDim2.new(0,500,0,475)})
		TabList.Visible=true; ElementsContainer.Visible=true
		task.wait(0.5); Debounce=false
	end

	local function Minimise()
		Debounce=true; Minimised=true
		TabList.Visible=false; ElementsContainer.Visible=false
		tw(Main,0.5,{Size=UDim2.new(0,500,0,45)})
		task.wait(0.5); Debounce=false
	end

	HideBtn.MouseButton1Click:Connect(function()
		if Debounce then return end
		if Hidden then Unhide() else HideUI(true) end
	end)

	ChangeSzBtn.MouseButton1Click:Connect(function()
		if Debounce then return end
		if Minimised then Maximise() else Minimise() end
	end)

	-- toggle keybind
	local rawKey = Settings.ToggleUIKeybind
	local keyName = "K"
	if type(rawKey)=="string" then keyName=rawKey:upper()
	elseif typeof(rawKey)=="EnumItem" then keyName=rawKey.Name end

	local hideConn = UIS.InputBegan:Connect(function(input, processed)
		if processed then return end
		if input.KeyCode==Enum.KeyCode[keyName] then
			if Debounce then return end
			if Hidden then Unhide() else HideUI(false) end
		end
	end)
	table.insert(keybindConnections, hideConn)

	-- ── Search logic ─────────────────────────────────────────────────────────
	local currentPage = nil

	SearchBtn.MouseButton1Click:Connect(function()
		searchOpen = not searchOpen
		SearchFrame.Visible = searchOpen
		if searchOpen then SearchInput:CaptureFocus() end
		if not searchOpen then SearchInput.Text="" end
	end)

	SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
		if not currentPage then return end
		local q = SearchInput.Text:lower()
		for _,el in ipairs(currentPage:GetChildren()) do
			if el:IsA("Frame") then
				if q=="" then el.Visible=true
				else
					local lbl = el:FindFirstChild("Title") or el:FindFirstChild("Content")
					local name = lbl and lbl.Text:lower() or el.Name:lower()
					el.Visible = name:find(q,1,true)~=nil
				end
			end
		end
	end)

	SearchInput.FocusLost:Connect(function()
		if SearchInput.Text=="" and searchOpen then
			task.wait(0.12); searchOpen=false; SearchFrame.Visible=false
		end
	end)

	-- ── Tab creation ─────────────────────────────────────────────────────────
	local FirstTab = false
	local Window   = {}

	function Window:CreateTab(Name, Image, Ext)
		-- Tab button
		local TabBtn = New("TextButton",{
			Text=Name, Name=Name,
			Font=Enum.Font.GothamSemibold, TextSize=13,
			BackgroundColor3=SelectedTheme.TabBackground,
			TextColor3=SelectedTheme.TabTextColor,
			AutoButtonColor=false, ZIndex=2,
			Size=UDim2.new(0,90,0,28),
			Parent=Ext and nil or TabList,
		})
		corner(8,TabBtn)
		local tabStroke = stroke(SelectedTheme.TabStroke,1,TabBtn)

		-- resize to text
		task.defer(function()
			TabBtn.Size = UDim2.new(0, math.max(TabBtn.TextBounds.X+24, 70), 0, 28)
		end)

		if Ext then return {} end -- hidden ext tab (e.g. settings)

		-- Tab page
		local Page = New("ScrollingFrame",{
			BackgroundTransparency=1,
			Size=UDim2.new(1,0,1,0),
			BorderSizePixel=0,
			ScrollBarThickness=3,
			ScrollBarImageColor3=SelectedTheme.ElementStroke,
			CanvasSize=UDim2.new(0,0,0,0),
			ScrollingEnabled=true,
			ScrollingDirection=Enum.ScrollingDirection.Y,
			Visible=false, Name=Name, Parent=ElementsContainer,
		})
		local pageLL = listLayout(Page,6)
		padding(10,10,10,10,Page)
		addThemeCb(function() Page.ScrollBarImageColor3=SelectedTheme.ElementStroke end)

		local function updateCanvas()
			task.defer(function()
				Page.CanvasSize = UDim2.new(0,0,0,pageLL.AbsoluteContentSize.Y+20)
			end)
		end
		pageLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)

		local function activateTab()
			-- deactivate all
			for _,p in ipairs(ElementsContainer:GetChildren()) do
				if p:IsA("ScrollingFrame") then p.Visible=false end
			end
			for _,tb in ipairs(TabList:GetChildren()) do
				if tb:IsA("TextButton") then
					tw(tb,0.25,{BackgroundColor3=SelectedTheme.TabBackground,TextColor3=SelectedTheme.TabTextColor,BackgroundTransparency=0.3})
					if tb:FindFirstChild("UIStroke") then tw(tb.UIStroke,0.25,{Transparency=0.5}) end
				end
			end
			-- activate this
			Page.Visible=true; currentPage=Page; updateCanvas()
			tw(TabBtn,0.25,{BackgroundColor3=SelectedTheme.TabBackgroundSelected,TextColor3=SelectedTheme.SelectedTabTextColor,BackgroundTransparency=0})
			tw(tabStroke,0.25,{Transparency=1})
			if SearchInput.Text~="" then SearchInput.Text="" end
		end

		if not FirstTab then
			FirstTab=Name; activateTab()
		else
			tw(TabBtn,0.25,{BackgroundTransparency=0.3,TextColor3=SelectedTheme.TabTextColor})
		end

		TabBtn.MouseButton1Click:Connect(function()
			if Minimised then return end
			activateTab()
		end)

		addThemeCb(function()
			tabStroke.Color=SelectedTheme.TabStroke
			if Page.Visible then
				TabBtn.BackgroundColor3=SelectedTheme.TabBackgroundSelected
				TabBtn.TextColor3=SelectedTheme.SelectedTabTextColor
			else
				TabBtn.BackgroundColor3=SelectedTheme.TabBackground
				TabBtn.TextColor3=SelectedTheme.TabTextColor
			end
		end)

		-- ── Element builders ─────────────────────────────────────────────────
		local Tab = {}

		-- base element frame
		local function baseFrame(h)
			local f = New("Frame",{
				BackgroundColor3=SelectedTheme.ElementBackground,
				Size=UDim2.new(1,0,0,h), BorderSizePixel=0, Parent=Page,
			})
			corner(6,f); stroke(SelectedTheme.ElementStroke,1,f)
			addThemeCb(function()
				if f and f.Parent then
					f.BackgroundColor3=SelectedTheme.ElementBackground
					f.UIStroke.Color=SelectedTheme.ElementStroke
				end
			end)
			updateCanvas()
			return f
		end

		local function hoverSetup(frame, btn)
			btn.MouseEnter:Connect(function() tw(frame,0.25,{BackgroundColor3=SelectedTheme.ElementBackgroundHover}) end)
			btn.MouseLeave:Connect(function() tw(frame,0.25,{BackgroundColor3=SelectedTheme.ElementBackground}) end)
		end

		local function titleLabel(parent, text)
			local l = New("TextLabel",{
				Name="Title", Text=text,
				Font=Enum.Font.GothamBold, TextSize=14,
				TextColor3=SelectedTheme.TextColor, BackgroundTransparency=1,
				Size=UDim2.new(1,-16,1,0), Position=UDim2.new(0,12,0,0),
				TextXAlignment=Enum.TextXAlignment.Left, Parent=parent,
			})
			addThemeCb(function() if l and l.Parent then l.TextColor3=SelectedTheme.TextColor end end)
			return l
		end

		-- ── CreateSection ────────────────────────────────────────────────────
		function Tab:CreateSection(SectionName)
			local sf = New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,22),Parent=Page})
			local lbl = New("TextLabel",{Text=(SectionName or ""):upper(),Font=Enum.Font.GothamBold,TextSize=11,TextColor3=SelectedTheme.TextColor,BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),TextXAlignment=Enum.TextXAlignment.Left,TextTransparency=0.4,Parent=sf})
			New("Frame",{BackgroundColor3=SelectedTheme.ElementStroke,Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BorderSizePixel=0,Parent=sf})
			addThemeCb(function() if lbl and lbl.Parent then lbl.TextColor3=SelectedTheme.TextColor end end)
			updateCanvas()
			local sv={}; function sv:Set(n) lbl.Text=(n or ""):upper() end; return sv
		end

		-- ── CreateDivider ─────────────────────────────────────────────────────
		function Tab:CreateDivider()
			local df = New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,14),Parent=Page})
			local line = New("Frame",{BackgroundColor3=SelectedTheme.ElementStroke,AnchorPoint=Vector2.new(0,0.5),Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,0.5,0),BorderSizePixel=0,Parent=df})
			tw(line,0.5,{BackgroundTransparency=0.15})
			addThemeCb(function() if line and line.Parent then line.BackgroundColor3=SelectedTheme.ElementStroke end end)
			updateCanvas()
			local dv={}; function dv:Set(v) df.Visible=v end; return dv
		end

		-- ── CreateLabel ───────────────────────────────────────────────────────
		function Tab:CreateLabel(LabelText, Icon, Color, IgnoreTheme)
			local f = New("Frame",{
				BackgroundColor3=Color or SelectedTheme.SecondaryElementBackground,
				Size=UDim2.new(1,0,0,32),BorderSizePixel=0,Parent=Page,
			})
			corner(6,f); stroke(Color or SelectedTheme.SecondaryElementStroke,1,f)
			local lbl = titleLabel(f, LabelText or "")
			lbl.Font=Enum.Font.GothamBold
			addThemeCb(function()
				if f and f.Parent then
					if not IgnoreTheme then
						f.BackgroundColor3=SelectedTheme.SecondaryElementBackground
						f.UIStroke.Color=SelectedTheme.SecondaryElementStroke
					end
				end
			end)
			updateCanvas()
			local lv={}
			function lv:Set(t,ic,c) lbl.Text=t or lbl.Text; if c and IgnoreTheme then f.BackgroundColor3=c end end
			return lv
		end

		-- ── CreateParagraph ───────────────────────────────────────────────────
		function Tab:CreateParagraph(cfg)
			cfg=cfg or{}
			local f = New("Frame",{
				BackgroundColor3=SelectedTheme.SecondaryElementBackground,
				Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
				BorderSizePixel=0,Parent=Page,
			})
			corner(6,f); stroke(SelectedTheme.SecondaryElementStroke,1,f); padding(8,10,12,12,f)
			local ll2=listLayout(f,4)
			local t=New("TextLabel",{Text=cfg.Title or "",Font=Enum.Font.GothamBold,TextSize=14,TextColor3=SelectedTheme.TextColor,BackgroundTransparency=1,Size=UDim2.new(1,0,0,18),TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
			local c=New("TextLabel",{Text=cfg.Content or "",Font=Enum.Font.Gotham,TextSize=13,TextColor3=SelectedTheme.TextColor,BackgroundTransparency=1,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,TextWrapped=true,TextXAlignment=Enum.TextXAlignment.Left,Parent=f})
			addThemeCb(function()
				if f and f.Parent then f.BackgroundColor3=SelectedTheme.SecondaryElementBackground f.UIStroke.Color=SelectedTheme.SecondaryElementStroke t.TextColor3=SelectedTheme.TextColor c.TextColor3=SelectedTheme.TextColor end
			end)
			updateCanvas()
			local pv={}; function pv:Set(s) if s.Title then t.Text=s.Title end; if s.Content then c.Text=s.Content end end; return pv
		end

		-- ── CreateButton ──────────────────────────────────────────────────────
		function Tab:CreateButton(ButtonSettings)
			ButtonSettings=ButtonSettings or{}
			local f=baseFrame(38)
			local click=New("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),ZIndex=2,Parent=f})
			local tl=titleLabel(f,ButtonSettings.Name or "Button")
			hoverSetup(f,click)
			click.MouseButton1Click:Connect(function()
				tw(f,0.15,{BackgroundColor3=SelectedTheme.ElementBackgroundHover})
				tw(f.UIStroke,0.15,{Transparency=1})
				local ok,err=pcall(ButtonSettings.Callback or function()end)
				if rayfieldDestroyed then return end
				if not ok then
					tl.Text="Callback Error"; tw(f,0.3,{BackgroundColor3=Color3.fromRGB(85,0,0)})
					task.wait(0.8); tl.Text=ButtonSettings.Name or "Button"; tw(f,0.3,{BackgroundColor3=SelectedTheme.ElementBackground})
				end
				tw(f,0.3,{BackgroundColor3=SelectedTheme.ElementBackground})
