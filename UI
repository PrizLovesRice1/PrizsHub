                    local function update()
                        local val = math.clamp(math.floor(((mouse.X - track.AbsolutePosition.X) / 290) * 255), 0, 255)
                        fill.Size = UDim2.new(0, val/255*290, 0, 10)
                        if channel == "r" then r = val; rL.Text = "R: "..val
                        elseif channel == "g" then g = val; gL.Text = "G: "..val
                        elseif channel == "b" then b = val; bL.Text = "B: "..val end
                        updateColor()
                    end
                    update()
                    local mc = mouse.Move:Connect(update)
                    local rc
                    rc = uis.InputEnded:Connect(function(i)
                        if i.UserInputType == Enum.UserInputType.MouseButton1 then
                            moving = false
                            mc:Disconnect()
                            rc:Disconnect()
                        end
                    end)
                end)
            end

            setupTrack(rTrack, rF, rL, "r")
            setupTrack(gTrack, gF, gL, "g")
            setupTrack(bTrack, bF, bL, "b")

            local pickerOpen = false
            cpBtn.MouseButton1Click:Connect(function()
                pickerOpen = not pickerOpen
                if pickerOpen then
                    cpFrame.ClipsDescendants = false
                    pickerPanel.Visible      = true
                    cpFrame:TweenSize(UDim2.new(0,394,0,136),"In","Quint",0.12)
                else
                    cpFrame:TweenSize(UDim2.new(0,394,0,42),"In","Quint",0.12)
                    task.wait(0.13)
                    pickerPanel.Visible      = false
                    cpFrame.ClipsDescendants = true
                end
                UpdateSize()
            end)

            local obj = { CurrentColor = initColor }
            function obj:Set(newColor)
                r, g, b = newColor.R*255, newColor.G*255, newColor.B*255
                rF.Size = UDim2.new(0, r/255*290, 0, 10); rL.Text = "R: "..math.floor(r)
                gF.Size = UDim2.new(0, g/255*290, 0, 10); gL.Text = "G: "..math.floor(g)
                bF.Size = UDim2.new(0, b/255*290, 0, 10); bL.Text = "B: "..math.floor(b)
                cpPreview.BackgroundColor3 = newColor
                obj.CurrentColor = newColor
                if flag then OrionLib.Flags[flag] = newColor end
                pcall(callback, newColor)
            end
            return obj
        end

        return ElementHandler
    end

    return SectionHandler
end

return OrionLib
