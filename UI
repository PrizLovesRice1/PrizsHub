-- ─── Helpers ──────────────────────────────────────────────────────────────────
local function safecall(f, ...) if f then pcall(f, ...) end end
local function callSafely(f, ...) if f then local ok,r = pcall(f, ...) if ok then return r end end end
local function ensureFolder(p) if isfolder and not callSafely(isfolder,p) then callSafely(makefolder,p) end end

local function tw(obj, t, props)
	TS:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Exponential), props):Play()
end

local function New(cls, props, children)
	local o = Instance.new(cls)
	for k,v in pairs(props or {}) do o[k]=v end
	for _,c in ipairs(children or {}) do c.Parent = o end
	return o
end

local function corner(r, parent)
	return New("UICorner",{CornerRadius=UDim.new(0,r or 8), Parent=parent})
end
local function stroke(color, thick, parent)
	return New("UIStroke",{Color=color or Color3.new(1,1,1), Thickness=thick or 1, Parent=parent})
end
local function padding(t,b,l,r,parent)
	return New("UIPadding",{PaddingTop=UDim.new(0,t or 0),PaddingBottom=UDim.new(0,b or 0),PaddingLeft=UDim.new(0,l or 0),PaddingRight=UDim.new(0,r or 0),Parent=parent})
end
local function listLayout(parent, pad, dir)
	return New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,pad or 0),FillDirection=dir or Enum.FillDirection.Vertical,Parent=parent})
end

