        -- ── Slider ────────────────────────────────────────────────────────────
        function ElementHandler:CreateSlider(opts)
            opts = opts or {}
            local sliderin    = opts.Name         or opts.Info or "Slider"
            local range       = opts.Range        or {0, 500}
            local minvalue    = range[1]
            local maxvalue    = range[2]
            local increment   = opts.Increment    or 1
            local suffix      = opts.Suffix       or ""
            local currentVal  = opts.CurrentValue or minvalue
            local flag        = opts.Flag         or nil
            local callback    = opts.Callback     or function() end

