            UIList.HorizontalAlignment = Enum.HorizontalAlignment.Center
            UIList.SortOrder           = Enum.SortOrder.LayoutOrder
            UIList.Padding             = UDim.new(0, 5)

            local function getSelectedText()
                local keys = {}
                for k in pairs(selected) do keys[#keys+1] = k end
                if #keys == 0 then return dInfo end
                return dInfo..": "..table.concat(keys, ", ")
            end

            local optionBtns = {}

            local function buildOptions(newList)
                for _, b in ipairs(optionBtns) do b:Destroy() end
                optionBtns = {}
                DropYSize = 42
                for _, v in ipairs(newList) do
                    local optionBtn = Instance.new("TextButton")
                    local oc        = Instance.new("UICorner")

                    optionBtn.Parent           = dropDownFrame
                    optionBtn.BackgroundColor3 = selected[v] and Color3.fromRGB(139, 0, 23) or Color3.fromRGB(118, 0, 20)
                    optionBtn.Size             = UDim2.new(0, 377, 0, 39)
                    optionBtn.Font             = Enum.Font.GothamSemibold
                    optionBtn.Text             = "   "..v
                    optionBtn.TextColor3       = Color3.fromRGB(255,255,255)
                    optionBtn.TextSize         = 14
                    optionBtn.TextXAlignment   = Enum.TextXAlignment.Left
                    oc.CornerRadius            = UDim.new(0, 3)
                    oc.Parent                  = optionBtn
                    DropYSize = DropYSize + 48
                    table.insert(optionBtns, optionBtn)

                    optionBtn.MouseButton1Click:Connect(function()
                        if multiSelect then
                            selected[v] = not selected[v]
                            optionBtn.BackgroundColor3 = selected[v] and Color3.fromRGB(139,0,23) or Color3.fromRGB(118,0,20)
                        else
                            for k in pairs(selected) do selected[k] = false end
                            selected[v] = true
                            for _, b in ipairs(optionBtns) do
                                b.BackgroundColor3 = Color3.fromRGB(118,0,20)
                            end
                            optionBtn.BackgroundColor3 = Color3.fromRGB(139,0,23)
                            dropDownFrame:TweenSize(UDim2.new(0,394,0,42),"In","Quint",0.10)
                            TweenService:Create(ImageButton, TweenInfo.new(0.10),{ Rotation = 0 }):Play()
                            task.wait(0.10)
                            UpdateSize()
                            isDropped = false
                        end
                        dropdownItem.Text = getSelectedText()
                        local selTable = {}
                        for k, sv in pairs(selected) do if sv then selTable[#selTable+1] = k end end
                        if flag then OrionLib.Flags[flag] = selTable end
                        callback(selTable)
                    end)
                end
            end

            buildOptions(list)

            ImageButton.MouseButton1Click:Connect(function()
                if isDropped then
                    isDropped = false
                    dropDownFrame:TweenSize(UDim2.new(0,394,0,42),"In","Quint",0.10)
                    TweenService:Create(ImageButton, TweenInfo.new(0.10),{ Rotation = 0 }):Play()
                    task.wait(0.10)
                    UpdateSize()
                else
                    isDropped = true
                    dropDownFrame:TweenSize(UDim2.new(0,394,0,DropYSize),"In","Quint",0.10)
                    TweenService:Create(ImageButton, TweenInfo.new(0.10),{ Rotation = 180 }):Play()
                    task.wait(0.10)
                    UpdateSize()
                end
            end)

            if flag then
                local selTable = {}
                for k, sv in pairs(selected) do if sv then selTable[#selTable+1] = k end end
                OrionLib.Flags[flag] = selTable
            end

            local obj = { CurrentOption = currentOptions }
            function obj:Refresh(newList)
                buildOptions(newList)
            end
            function obj:Set(newOptions)
                selected = {}
                for _, v in ipairs(newOptions) do selected[v] = true end
                dropdownItem.Text = getSelectedText()
                for _, b in ipairs(optionBtns) do
                    local bText = b.Text:gsub("^%s+", "")
                    b.BackgroundColor3 = selected[bText] and Color3.fromRGB(139,0,23) or Color3.fromRGB(118,0,20)
                end
                obj.CurrentOption = newOptions
                if flag then OrionLib.Flags[flag] = newOptions end
                callback(newOptions)
            end
            return obj
        end

