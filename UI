			local knob=New("Frame",{BackgroundColor3=SelectedTheme.ToggleDisabled,Size=UDim2.new(0,14,0,14),Position=UDim2.new(0,3,0.5,-7),BorderSizePixel=0,ZIndex=3,Parent=switchBg})
			corner(8,knob)
