-- ─── Config Save/Load ─────────────────────────────────────────────────────────
local function SaveConfiguration()
	if not CEnabled or not globalLoaded then return end
	local data = {}
	for flag, v in pairs(RayfieldLibrary.Flags) do
		if v.Type == "ColorPicker" then
			data[flag] = {R=v.Color.R*255,G=v.Color.G*255,B=v.Color.B*255}
		else
			if typeof(v.CurrentValue)=="boolean" then
				data[flag] = v.CurrentValue
			else
				data[flag] = v.CurrentValue or v.CurrentKeybind or v.CurrentOption or v.Color
			end
		end
	end
	callSafely(writefile, CFolder.."/"..CFileName..".rfld", tostring(HTTP:JSONEncode(data)))
end

local function LoadConfiguration(config)
	local ok, data = pcall(function() return HTTP:JSONDecode(config) end)
	if not ok then return false end
	local changed = false
	for flag, fv in pairs(RayfieldLibrary.Flags) do
		local val = data[flag]
		if val ~= nil then
			task.spawn(function()
				if fv.Type=="ColorPicker" then
					changed=true; fv:Set(Color3.fromRGB(val.R,val.G,val.B))
				else
					if (fv.CurrentValue or fv.CurrentKeybind or fv.CurrentOption or fv.Color) ~= val then
						changed=true; fv:Set(val)
					end
				end
			end)
		end
	end
	return changed
end

function RayfieldLibrary:LoadConfiguration()
	if not CEnabled then globalLoaded=true return end
	local notified, loaded
	local ok,err = pcall(function()
		if isfile and callSafely(isfile, CFolder.."/"..CFileName..".rfld") then
			loaded = LoadConfiguration(callSafely(readfile, CFolder.."/"..CFileName..".rfld"))
		end
	end)
	if ok and loaded then
		RayfieldLibrary:Notify({Title="Configurations",Content="Configuration loaded from previous session.",Duration=4})
	elseif not ok then
		warn("OrionLib Config Error: "..tostring(err))
	end
	globalLoaded = true
end

