		-- ── CreateDropdown ────────────────────────────────────────────────────
		function Tab:CreateDropdown(DropdownSettings)
			DropdownSettings=DropdownSettings or{}
			DropdownSettings.Type="Dropdown"
			local isMulti=DropdownSettings.MultipleOptions or false
			if DropdownSettings.CurrentOption then
				if type(DropdownSettings.CurrentOption)=="string" then DropdownSettings.CurrentOption={DropdownSettings.CurrentOption} end
			else DropdownSettings.CurrentOption={} end
			if not isMulti then DropdownSettings.CurrentOption={DropdownSettings.CurrentOption[1]} end

			local function getSelectedText()
				local n=#DropdownSettings.CurrentOption
				if n==0 then return "None"
				elseif n==1 then return DropdownSettings.CurrentOption[1]
				else return "Various" end
			end

			-- wrapper that expands/contracts
			local wrapper=New("Frame",{BackgroundTransparency=1,Size=UDim2.new(1,0,0,38),ClipsDescendants=true,Parent=Page})
			updateCanvas()

			local f=New("Frame",{BackgroundColor3=SelectedTheme.ElementBackground,Size=UDim2.new(1,0,0,38),BorderSizePixel=0,Parent=wrapper})
			corner(6,f); stroke(SelectedTheme.ElementStroke,1,f)
			addThemeCb(function() if f and f.Parent then f.BackgroundColor3=SelectedTheme.ElementBackground f.UIStroke.Color=SelectedTheme.ElementStroke end end)

			local tl=titleLabel(f, DropdownSettings.Name or "Dropdown")
			local selLbl=New("TextLabel",{Text=getSelectedText(),Font=Enum.Font.Gotham,TextSize=13,TextColor3=SelectedTheme.TextColor,BackgroundTransparency=1,Size=UDim2.new(0,130,1,0),Position=UDim2.new(1,-162,0,0),TextXAlignment=Enum.TextXAlignment.Right,ZIndex=2,Parent=f})
			local arrow=New("ImageLabel",{Image="rbxassetid://7072706796",BackgroundTransparency=1,Size=UDim2.new(0,16,0,16),Position=UDim2.new(1,-26,0.5,-8),ImageColor3=SelectedTheme.TextColor,ZIndex=2,Parent=f})
			addThemeCb(function() if selLbl and selLbl.Parent then selLbl.TextColor3=SelectedTheme.TextColor arrow.ImageColor3=SelectedTheme.TextColor end end)

			-- list
			local listFrame=New("Frame",{BackgroundColor3=SelectedTheme.DropdownUnselected,Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,0,42),BorderSizePixel=0,Parent=wrapper})
			corner(6,listFrame); stroke(SelectedTheme.ElementStroke,1,listFrame); padding(4,4,4,4,listFrame)
			local listLL=listLayout(listFrame,3)
			addThemeCb(function() if listFrame and listFrame.Parent then listFrame.BackgroundColor3=SelectedTheme.DropdownUnselected listFrame.UIStroke.Color=SelectedTheme.ElementStroke end end)

			local opened=false
			local optionBtns={}

			local function rebuildList(opts)
				for _,b in ipairs(optionBtns) do b:Destroy() end; optionBtns={}
				for _,opt in ipairs(opts or {}) do
					local isSel=table.find(DropdownSettings.CurrentOption,opt)~=nil
					local ob=New("TextButton",{
						Text="  "..opt, Name=opt,
						Font=Enum.Font.Gotham, TextSize=13,
						TextColor3=SelectedTheme.TextColor, TextXAlignment=Enum.TextXAlignment.Left,
						BackgroundColor3=isSel and SelectedTheme.DropdownSelected or SelectedTheme.DropdownUnselected,
						BorderSizePixel=0, Size=UDim2.new(1,0,0,28), AutoButtonColor=false, Parent=listFrame,
					})
					corner(4,ob)
					addThemeCb(function()
						if ob and ob.Parent then
							local s=table.find(DropdownSettings.CurrentOption,opt)~=nil
							ob.BackgroundColor3=s and SelectedTheme.DropdownSelected or SelectedTheme.DropdownUnselected
							ob.TextColor3=SelectedTheme.TextColor
						end
					end)
					ob.MouseButton1Click:Connect(function()
						if isMulti then
							local idx=table.find(DropdownSettings.CurrentOption,opt)
							if idx then table.remove(DropdownSettings.CurrentOption,idx)
							else table.insert(DropdownSettings.CurrentOption,opt) end
							ob.BackgroundColor3=table.find(DropdownSettings.CurrentOption,opt) and SelectedTheme.DropdownSelected or SelectedTheme.DropdownUnselected
						else
							DropdownSettings.CurrentOption={opt}
							for _,b2 in ipairs(optionBtns) do b2.BackgroundColor3=SelectedTheme.DropdownUnselected end
							ob.BackgroundColor3=SelectedTheme.DropdownSelected
							-- close
							opened=false
							tw(arrow,0.2,{Rotation=180})
							tw(wrapper,0.2,{Size=UDim2.new(1,0,0,38)})
							task.delay(0.2,function() wrapper.ClipsDescendants=true end)
							updateCanvas()
						end
						selLbl.Text=getSelectedText()
						pcall(DropdownSettings.Callback or function()end, DropdownSettings.CurrentOption)
						if not DropdownSettings.Ext then SaveConfiguration() end
					end)
					table.insert(optionBtns,ob)
				end
				-- update list height
				task.defer(function()
					listFrame.Size=UDim2.new(1,0,0,listLL.AbsoluteContentSize.Y+8)
				end)
			end

			rebuildList(DropdownSettings.Options or {})

			local headerBtn=New("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),ZIndex=3,Parent=f})
			hoverSetup(f,headerBtn)
			arrow.Rotation=180

			headerBtn.MouseButton1Click:Connect(function()
				if Debounce then return end
				opened=not opened
				tw(arrow,0.3,{Rotation=opened and 0 or 180})
				if opened then
					wrapper.ClipsDescendants=false
					task.defer(function()
						local h=38+8+listLL.AbsoluteContentSize.Y+8
						tw(wrapper,0.3,{Size=UDim2.new(1,0,0,h)})
						updateCanvas()
					end)
				else
					tw(wrapper,0.3,{Size=UDim2.new(1,0,0,38)})
					task.delay(0.3,function() wrapper.ClipsDescendants=true end)
					updateCanvas()
				end
			end)

			function DropdownSettings:Set(newOpt)
				if type(newOpt)=="string" then newOpt={newOpt} end
				DropdownSettings.CurrentOption=isMulti and newOpt or {newOpt[1]}
				selLbl.Text=getSelectedText()
				for _,ob in ipairs(optionBtns) do
					ob.BackgroundColor3=table.find(DropdownSettings.CurrentOption,ob.Name) and SelectedTheme.DropdownSelected or SelectedTheme.DropdownUnselected
				end
				pcall(DropdownSettings.Callback or function()end, DropdownSettings.CurrentOption)
			end

			function DropdownSettings:Refresh(newOpts)
				DropdownSettings.Options=newOpts
				DropdownSettings.CurrentOption={}
				selLbl.Text="None"
				rebuildList(newOpts)
			end

			if Settings.ConfigurationSaving and Settings.ConfigurationSaving.Enabled and DropdownSettings.Flag and not DropdownSettings.Ext then
				RayfieldLibrary.Flags[DropdownSettings.Flag]=DropdownSettings
			end
			return DropdownSettings
		end

		-- ── CreateKeybind ─────────────────────────────────────────────────────
		function Tab:CreateKeybind(KeybindSettings)
			KeybindSettings=KeybindSettings or{}
			KeybindSettings.Type="Bind"
			local checking=false

			local f=baseFrame(38)
			hoverSetup(f,New("TextButton",{Text="",BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),ZIndex=2,Parent=f}))
			titleLabel(f, KeybindSettings.Name or "Keybind")

			local kbWrap=New("Frame",{BackgroundColor3=SelectedTheme.InputBackground,Size=UDim2.new(0,24,0,26),Position=UDim2.new(1,-12,0.5,-13),AnchorPoint=Vector2.new(1,0),BorderSizePixel=0,ZIndex=2,Parent=f})
			corner(6,kbWrap); stroke(SelectedTheme.InputStroke,1,kbWrap)
			local kbBox=New("TextBox",{Text=KeybindSettings.CurrentKeybind or "None",Font=Enum.Font.GothamBold,TextSize=13,TextColor3=SelectedTheme.TextColor,BackgroundTransparency=1,Size=UDim2.new(1,-8,1,0),Position=UDim2.new(0,4,0,0),ClearTextOnFocus=false,ZIndex=3,Parent=kbWrap})
			addThemeCb(function() if kbWrap and kbWrap.Parent then kbWrap.BackgroundColor3=SelectedTheme.InputBackground kbWrap.UIStroke.Color=SelectedTheme.InputStroke kbBox.TextColor3=SelectedTheme.TextColor end end)

			kbBox:GetPropertyChangedSignal("Text"):Connect(function()
				local w=math.max(kbBox.TextBounds.X+24,24)
				tw(kbWrap,0.2,{Size=UDim2.new(0,w,0,26)})
				kbWrap.Position=UDim2.new(1,-math.max(w+12,36),0.5,-13)
			end)

			kbBox.Focused:Connect(function() checking=true kbBox.Text="" end)
			kbBox.FocusLost:Connect(function()
				checking=false
				if kbBox.Text=="" then kbBox.Text=KeybindSettings.CurrentKeybind or "None" end
				if not KeybindSettings.Ext then SaveConfiguration() end
			end)

			local conn=UIS.InputBegan:Connect(function(input,processed)
				if checking then
					if input.KeyCode~=Enum.KeyCode.Unknown then
						local kn=input.KeyCode.Name
						kbBox.Text=kn; KeybindSettings.CurrentKeybind=kn
						kbBox:ReleaseFocus()
						if KeybindSettings.CallOnChange then pcall(KeybindSettings.Callback or function()end, kn) end
						if not KeybindSettings.Ext then SaveConfiguration() end
					end
				elseif not KeybindSettings.CallOnChange and not processed and KeybindSettings.CurrentKeybind and input.KeyCode==Enum.KeyCode[KeybindSettings.CurrentKeybind] then
					if not KeybindSettings.HoldToInteract then
						pcall(KeybindSettings.Callback or function()end)
					else
						local held=true
						local c2; c2=input.Changed:Connect(function(p) if p=="UserInputState" then held=false c2:Disconnect() end end)
						task.wait(0.25)
						if held then
							local loop; loop=RS.Stepped:Connect(function()
								if not held then pcall(KeybindSettings.Callback or function()end,false) loop:Disconnect()
								else pcall(KeybindSettings.Callback or function()end,true) end
							end)
						end
					end
				end
			end)
			table.insert(keybindConnections,conn)

			function KeybindSettings:Set(k)
				k=type(k)=="string" and k or (typeof(k)=="EnumItem" and k.Name or tostring(k))
				self.CurrentKeybind=k; kbBox.Text=k
				if self.CallOnChange then pcall(self.Callback or function()end,k) end
				if not self.Ext then SaveConfiguration() end
			end

			if Settings.ConfigurationSaving and Settings.ConfigurationSaving.Enabled and KeybindSettings.Flag and not KeybindSettings.Ext then
				RayfieldLibrary.Flags[KeybindSettings.Flag]=KeybindSettings
			end
			return KeybindSettings
		end

